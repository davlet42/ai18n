{
  "name": "i18n-agent-nest",
  "version": "0.1.0",
  "description": "Serve i18n-agent bundles from your own NestJS backend \u2014 self-hosted translation delivery with ETag caching. No third-party cloud.",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "i18n-agent": "file:../.."
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "supertest": "^7.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": "https://github.com/davlet42/ai18n",
  "keywords": [
    "i18n",
    "nestjs",
    "localization",
    "translations",
    "self-hosted",
    "ota"
  ]
}
