            "value": "¿Olvidaste tu contraseña?"
          }
        }
      }
    },
    "auth.errors.invalid": {
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Wrong email or password. %lld attempt left"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Wrong email or password. %lld attempts left"
                }
              }
            }
          }
        },
        "ru": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Неверный email или пароль. осталось %lld попытка"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Неверный email или пароль. осталось %lld попыток"
                }
              }
            }
          }
        },
        "es": {
          "variations": {
            "plural": {
              "one": {
