{
  "sourceLanguage": "en",
  "strings": {
    "auth.login.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in to your account"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Войдите в свой аккаунт"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sesión en tu cuenta"
          }
        }
      }
    },
    "auth.login.button": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log in"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Войти"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar sesión"
          }
        }
      }
    },
    "auth.login.forgot": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Forgot password?"
          }
        },
        "ru": {
          "stringUnit": {
