{
  "name": "i18n-agent",
  "version": "0.5.0",
  "description": "Locale files translated by the coding-agent subscription you already pay for — diff-synced via a lockfile, placeholder-safe, manual edits stay sacred. No API keys, no per-word fees.",
  "type": "module",
  "bin": {
    "i18n-agent": "dist/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "agent-skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && node --test test/*.test.mjs && npm run test -w i18n-agent-nest --if-present"
  },
  "dependencies": {
    "@cursor-translate/core": "^0.2.11",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davlet42/ai18n.git"
  },
  "keywords": [
    "i18n",
    "localization",
    "l10n",
    "translation",
    "locale",
    "ai",
    "claude",
    "claude-code",
    "cursor",
    "agent",
    "i18next"
  ],
  "workspaces": [
    "packages/*"
  ]
}
